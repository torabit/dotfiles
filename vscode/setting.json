{
  "search.quickOpen.includeHistory": true,
  "search.quickOpen.includeSymbols": true,
  "editor.fontFamily": "FixedsysExcelsior Nerd Font",
  "editor.tabSize": 2,
  "editor.fontSize": 13,
  "editor.wordWrapColumn": 100,
  "editor.wordWrap": "wordWrapColumn",
  "editor.minimap.enabled": false,
  "editor.tabCompletion": "off",
  "editor.lineNumbers": "relative",
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "solid",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.scrollBeyondLastLine": false,
  "editor.linkedEditing": true,
  "terminal.integrated.fontFamily": "HackGen35 Console NF",
  "terminal.integrated.fontSize": 12,
  "git.alwaysShowStagedChangesResourceGroup": true,
  "git.openDiffOnClick": true,
  "git.showProgress": true,
  "git.showPushSuccessNotification": true,
  "gitlens.hovers.currentLine.over": "line",
  "workbench.colorTheme": "PaperColor",
  "rust-analyzer.inlayHints.chainingHints.enable": false,
  "rust-analyzer.inlayHints.parameterHints.enable": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "path-intellisense.absolutePathToWorkspace": false,
  "path-intellisense.showHiddenFiles": true,
  "explorer.confirmDragAndDrop": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<C-h>"],
      "after": ["<C-w>", "h"]
    },
    {
      "before": ["<C-j>"],
      "after": ["<C-w>", "j"]
    },
    {
      "before": ["<C-k>"],
      "after": ["<C-w>", "k"]
    },
    {
      "before": ["<C-l>"],
      "after": ["<C-w>", "l"]
    },
    {
      "before": ["g", "D"],
      "commands": [
        {
          "commnad": "editor.action.previewDeclaration"
        }
      ]
    },
    {
      "before": ["g", "d"],
      "commands": [
        {
          "command": "editor.action.peekDefinition"
        }
      ]
    },
    {
      "before": ["K"],
      "commands": [
        {
          "command": "editor.action.showHover"
        }
      ]
    },
    {
      "before": ["<Leader>", "r", "n"],
      "commands": [
        {
          "command": "editor.action.rename"
        }
      ]
    },
    {
      "before": ["]", "e"],
      "commands": [
        {
          "command": "editor.action.marker.next"
        }
      ]
    },
    {
      "before": ["[", "e"],
      "commands": [
        {
          "command": "editor.action.marker.prev"
        }
      ]
    },
    {
      "before": ["s", "s"],
      "commands": [":split", "<Return>", "<C-w>", "w"]
    },
    {
      "before": ["s", "v"],
      "commands": [":vsplit", "<Return>", "<C-w>", "w"]
    },
    {
      "before": ["<tab>"],
      "after": ["g", "t"]
    },
    {
      "before": ["<s-tab>"],
      "after": ["g", "T"]
    },
    {
      "before": ["<Leader>", "q"],
      "commands": [":qa"]
    },
    {
      "before": ["<Leader>", "x"],
      "commands": [":x!"]
    },
    {
      "before": ["<Leader>", "d"],
      "commands": [":q!"]
    },
    {
      "before": ["<Leader>", "w"],
      "commands": [":w"]
    },
    {
      "before": ["<Leader>", "e"],
      "commands": [{ "command": "workbench.action.toggleSidebarVisibility" }]
    },
    {
      "before": ["<Leader>", "<Leader>"],
      "commands": [{ "command": "workbench.action.quickOpen" }]
    },
    {
      "before": ["t", "e"],
      "commands": [":tabedit", "<Return>"]
    },
    {
      "before": ["g", "c", "c"],
      "commands": [
        {
          "command": "editor.action.commentLine"
        }
      ]
    },
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<Leader>", "r", "n"],
      "commands": [
        {
          "command": "editor.action.rename"
        }
      ]
    }
  ],
  "terminal.integrated.env.osx": {},
  "console-ninja.featureSet": "Community",
  "workbench.iconTheme": "material-icon-theme",
  "[ruby]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.defaultFormatter": "Shopify.ruby-lsp"
  },
  "hediet.vscode-drawio.resizeImages": null
}
